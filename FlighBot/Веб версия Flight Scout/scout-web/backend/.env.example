# backend/.env  — скопируйте в .env и заполните

# Travelpayouts API (из вашего бота)
AVIASALES_TOKEN=ваш_token
AVIASALES_MARKER=ваш_marker
AVIASALES_HOST=beta.aviasales.ru

# FlyStack (из вашего бота)
FLYSTACK_API_KEY=ваш_ключ

# Redis (опционально, но рекомендуется)
REDIS_URL=redis://localhost:6379/0

# URL фронтенда (для CORS)
FRONTEND_URL=http://localhost:5173
